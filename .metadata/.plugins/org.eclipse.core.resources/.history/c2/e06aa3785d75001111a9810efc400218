package com.ebustillos.ms.negocio.gestionpedidos.entity;

import java.io.Serializable;
import jakarta.persistence.Column;
import jakarta.persistence.Entity;
import jakarta.persistence.GeneratedValue;
import jakarta.persistence.GenerationType;
import jakarta.persistence.Id;
import jakarta.persistence.Table;
import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

@Data
@NoArgsConstructor
@AllArgsConstructor
@Entity(name = "DetallePedido")
@Table(name = "tbl_detalle_pedido", catalog = "db_ms_pedidos", schema = "ventas")
public class DetallePedidoEntity implements Serializable {

   	@Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    @Column(name = "id_detalle_pedido")
    private Long idDetallePedido;
   	
   	@Column(name = "id_pedido")
    private Long idPedido;
   	
	@Column(name = "id_producto")
    private Long idProducto;

    @Column(name = "cantidad")
    private Integer cantidad;
    
    @Column(name = "precio")
    private  Double precio;

    @Column(name = "subtotal")
    private  Double subtotal;
}
